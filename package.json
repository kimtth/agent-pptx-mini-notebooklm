    "setup:python-env": "node scripts/setup-python.mjs",
    "verify:python-env": "node scripts/verify-python-env.mjs",
    "test:connections": "node scripts/test-connections.mjs"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@fluentui/svg-icons": "^1.1.320",
    "@github/copilot": "^1.0.3",
    "@github/copilot-sdk": "^0.1.32",
    "@github/copilot-win32-x64": "1.0.3",
    "@iconify/react": "^6.0.2",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "balanced-match": "^4.0.4",
    "cheerio": "^1.2.0",
    "csv-parse": "^6.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.11.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
